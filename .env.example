# Required secrets
OPENAI_API_KEY=your_openai_api_key
TAVILY_API_KEY=your_tavily_api_key

# Preferred MongoDB variable name.
# This app uses MongoDB Atlas Vector Search on Smart_IPO.embeddings
# with an index named vector_index.
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/

# Optional LangSmith tracing
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=smart-ipo-analyzer
